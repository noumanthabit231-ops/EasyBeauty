# Supabase — вставьте сюда свои ключи (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — используется ТОЛЬКО на сервере (супер-админка). Никогда не коммитить!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email супер-администратора (владелец SaaS). Этот аккаунт получит доступ к /admin
NEXT_PUBLIC_SUPER_ADMIN_EMAIL=noumanthabit231@gmail.com
